{
  "name": "@baita/backend",
  "version": "1.0.0",
  "author": "Joao Ricardo Cardoso",
  "scripts": {
    "start": "AWS_PROFILE=baita serverless offline --httpPort 5000 --stage prod",
    "deploy": "AWS_PROFILE=baita serverless deploy --stage prod",
    "docs": "tsx src/docs/generate.ts && aws s3 sync src/docs/ s3://baita-prod-docs/ --region us-east-1 --exclude '*.ts'",
    "test": "jest --watchAll",
    "test:run": "jest --no-coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' --fix",
    "format": "prettier './**/*.{js,ts,json,yml}' --write",
    "spell": "cspell --config ../../cspell.json 'src/**/*.ts'",
    "knip": "knip"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewayv2": "^3.948.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.948.0",
    "@aws-sdk/client-dynamodb": "^3.948.0",
    "@aws-sdk/client-lambda": "^3.948.0",
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/client-scheduler": "^3.948.0",
    "@aws-sdk/lib-dynamodb": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.948.0",
    "@baita/shared": "workspace:*",
    "axios": "^1.13.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "jwks-rsa": "^4.0.1",
    "qs": "^6.14.0",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "uuid": "$uuid",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/qs": "^6.15.1",
    "@types/web-push": "^3.6.4",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "jest": "^30.2.0",
    "js-yaml": "^4.2.0",
    "knip": "^6.14.2",
    "prettier": "^3.7.4",
    "serverless": "^3.40.0",
    "serverless-deployment-bucket": "^1.6.0",
    "serverless-domain-manager": "^8.0.0",
    "serverless-esbuild": "^1.56.1",
    "serverless-offline": "^13.10.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "zod-to-json-schema": "^3.25.2"
  }
}
